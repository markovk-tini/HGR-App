# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/

# Virtual envs
.venv/
venv/
env/

# Build / packaging artifacts
build/
dist/
release/
# Ignore the contents of installers/ EXCEPT the .iss source files.
# The .iss carries install-time configuration (per-user vs Program
# Files location, CloseApplications directives, version) that has
# to live in the repo so every build produces a consistent installer.
installers/*
!installers/windows/
installers/windows/*
!installers/windows/*.iss
*.spec.bak

# PyInstaller distribution staging
*.manifest
*.exe

# IDE / editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Model weights (downloaded / cached locally; user has a model dir)
models/
# Exception: the small (~16 MB total) MediaPipe-equivalent ONNX
# models for the GPU hand-tracking path. These ship with the app
# (auto-bundled by PyInstaller via the assets/ glob) so the GPU
# Mode toggle works on a fresh install without a separate download
# step. The .task file is the original MediaPipe bundle the .onnx
# files were sourced against — kept for reproducibility.
!assets/models/
!assets/models/*.onnx
!assets/models/*.npy
!assets/models/*.task

# Third-party source + built artifacts (fetched/rebuilt via scripts in builder/)
whisper.cpp/
whisper_bundle/
llama.cpp/

# ONNX conversion reference material — not used at runtime. Holds
# the original MediaPipe TFLite weights + OpenCV Zoo reference
# scripts that were adapted into
# src/hgr/gesture/tracking/onnx_runtime.py. The shipping .onnx
# files in assets/models/ come from OpenCV Zoo
# (https://github.com/opencv/opencv_zoo, BSD-3-Clause), NOT from a
# local conversion of these TFLite weights — so the directory is
# pure reference / experimentation. Kept out of the repo to avoid
# carrying ~7.6 MB of binaries; re-fetch from:
#   - MediaPipe hand assets:
#     https://storage.googleapis.com/mediapipe-models/hand_landmarker/
#   - OpenCV Zoo reference Python:
#     https://github.com/opencv/opencv_zoo/tree/main/models/handpose_estimation_mediapipe
tools/onnx_conversion/

# Agent / tooling state
.agents/
.claude/

# Large vendored pipelines
mp_modules/

# Test output
tests/output/
